{
  "version": 2,
  "builds": [
    {
      "src": "api.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/dashboard/(.*)",
      "dest": "/public/$1"
    },
    {
      "src": "/(favicon.*)",
      "dest": "/public/$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "api.py"
    },
    {
      "src": "/(.*)",
      "dest": "api.py"
    }
  ]
}
